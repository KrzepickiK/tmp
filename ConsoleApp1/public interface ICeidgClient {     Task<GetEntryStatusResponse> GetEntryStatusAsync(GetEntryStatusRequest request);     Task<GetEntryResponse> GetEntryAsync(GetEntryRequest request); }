using System.ServiceModel.Channels;

private Message CreateMessage(string action = "http://tempuri.org/IApiService/GetEntryStatus")
{
    return Message.CreateMessage(
        MessageVersion.Soap12WSAddressing10,
        action,
        "body"
    );
}



public class CeidgAddressingInspectorTests
{
    private readonly CeidgAddressingInspector _inspector = new();

    [Fact]
    public void BeforeSendRequest_Should_Set_Correct_Action()
    {
        // arrange
        var message = CreateMessage();
        var channel = new Mock<IClientChannel>();
        channel.Setup(c => c.RemoteAddress)
               .Returns(new EndpointAddress("https://test"));

        // act
        _inspector.BeforeSendRequest(ref message, channel.Object);

        // assert
        message.Headers.Action.Should().Be(
            "http://zeto.bialystok.pl/IApiService/GetEntryStatus");
    }
}


[Fact]
public void BeforeSendRequest_Should_Add_Required_Headers()
{
    var message = CreateMessage();
    var channel = new Mock<IClientChannel>();
    channel.Setup(c => c.RemoteAddress)
           .Returns(new EndpointAddress("https://test"));

    _inspector.BeforeSendRequest(ref message, channel.Object);

    message.Headers.FindHeader("To", "http://www.w3.org/2005/08/addressing")
        .Should().BeGreaterThanOrEqualTo(0);

    message.Headers.FindHeader("ReplyTo", "http://www.w3.org/2005/08/addressing")
        .Should().BeGreaterThanOrEqualTo(0);

    message.Headers.FindHeader("ActivityId", "http://schemas.microsoft.com/diagnostics")
        .Should().BeGreaterThanOrEqualTo(0);
}


[Fact]
public void BeforeSendRequest_Should_Add_Valid_ActivityId()
{
    var message = CreateMessage();
    var channel = new Mock<IClientChannel>();
    channel.Setup(c => c.RemoteAddress)
           .Returns(new EndpointAddress("https://test"));

    _inspector.BeforeSendRequest(ref message, channel.Object);

    var index = message.Headers.FindHeader(
        "ActivityId",
        "http://schemas.microsoft.com/diagnostics");

    var value = message.Headers.GetHeader<string>(index);

    Guid.TryParse(value, out var guid).Should().BeTrue();
}



[Fact]
public void BeforeSendRequest_Should_Handle_Null_Action()
{
    var message = Message.CreateMessage(
        MessageVersion.Soap12WSAddressing10,
        null,
        "body");

    var channel = new Mock<IClientChannel>();
    channel.Setup(c => c.RemoteAddress)
           .Returns(new EndpointAddress("https://test"));

    var act = () => _inspector.BeforeSendRequest(ref message, channel.Object);

    act.Should().NotThrow();
}











public class CeidgEndpointBehaviorTests
{
    [Fact]
    public void ApplyClientBehavior_Should_Add_Inspector()
    {
        // arrange
        var inspector = new Mock<IClientMessageInspector>();
        var behavior = new CeidgEndpointBehavior(inspector.Object);

        var clientRuntime = new ClientRuntime("test", "test");
        var endpoint = new ServiceEndpoint();

        // act
        behavior.ApplyClientBehavior(endpoint, clientRuntime);

        // assert
        clientRuntime.ClientMessageInspectors.Should().Contain(inspector.Object);
    }
}





[Fact]
public void Inspector_Should_Modify_Real_Message()
{
    var inspector = new CeidgAddressingInspector();

    var message = Message.CreateMessage(
        MessageVersion.Soap12WSAddressing10,
        "http://tempuri.org/IApiService/GetEntry",
        "body");

    var channel = new Mock<IClientChannel>();
    channel.Setup(c => c.RemoteAddress)
           .Returns(new EndpointAddress("https://real"));

    inspector.BeforeSendRequest(ref message, channel.Object);

    message.Headers.Action.Should().Contain("zeto.bialystok.pl");
}
