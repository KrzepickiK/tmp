public static class ErrorMappings
{
    public static TransferError ToTransferError(this Microservice.Common.Validation.Error src)
    {
        if (src == null) return null;

        return new TransferError
        {
            ErrorCode = src.ValidationErrorTitle,
            ErrorField = src.ValidationErrorField,
            ErrorDescription = src.ValidationErrorMessage
        };
    }

    public static Microservice.Common.Validation.Error ToValidationError(
        this Common.Rest.BMDomainMicroAccountingApi.TransferError src)
    {
        if (src == null) return null;

        return new Microservice.Common.Validation.Error
        {
            ValidationErrorTitle = src.ErrorCode,
            ValidationErrorField = src.ErrorField,
            ValidationErrorMessage = src.ErrorDescription
        };
    }
}





public static class AccountMappings
{
    public static TransferAccount ToDomain(
        this Common.Rest.BMDomainAccountsResourceProxyApi.AccountItem src)
    {
        if (src == null) return null;

        return new TransferAccount
        {
            Balance = src.AvailableBalance,
            CurrencyCode = src.AccountCurrencyCode
        };
    }
}







public static class TransferMappings
{
    public static TransferDto ToDto(this Transfer src, IMapper mapper)
    {
        if (src == null) return null;

        return new TransferDto
        {
            Id = src.Id,
            Amount = src.Amount,

            Account = mapper.Map<TransferAccount>(src.Account),

            Errors = src.Errors?
                .Select(e => mapper.Map<TransferError>(e))
                .ToList() ?? new List<TransferError>()
        };
    }
}
