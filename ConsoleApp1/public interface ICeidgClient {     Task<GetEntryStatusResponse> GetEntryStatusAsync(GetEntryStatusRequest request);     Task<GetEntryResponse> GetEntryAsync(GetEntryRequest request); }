using System;
using System.Linq;
using System.Reflection;
using System.ServiceModel.Description;
using System.ServiceModel.Dispatcher;
using FluentAssertions;
using Moq;
using Xunit;

public class CeidgEndpointBehaviorTests
{
    [Fact]
    public void ApplyClientBehavior_Should_Add_Inspector_To_ClientRuntime()
    {
        // arrange
        var inspector = new Mock<IClientMessageInspector>().Object;
        var behavior = new CeidgEndpointBehavior(inspector);

        // ✅ poprawny ServiceEndpoint (z kontraktem)
        var contract = ContractDescription.GetContract(typeof(IDisposable));
        var endpoint = new ServiceEndpoint(contract);

        // ✅ ClientRuntime przez reflection
        var ctor = typeof(ClientRuntime)
            .GetConstructors(BindingFlags.Instance | BindingFlags.NonPublic)
            .First(c =>
            {
                var parameters = c.GetParameters();
                return parameters.Length == 2 &&
                       parameters[0].ParameterType == typeof(string) &&
                       parameters[1].ParameterType == typeof(string);
            });

        var clientRuntime = (ClientRuntime)ctor.Invoke(new object[] { "test", "test" });

        // act
        behavior.ApplyClientBehavior(endpoint, clientRuntime);

        // assert
        clientRuntime.ClientMessageInspectors.Should().Contain(inspector);
    }



[Fact]
public void ApplyClientBehavior_Should_Not_Throw_When_Inspector_Is_Added()
{
    var inspector = new Mock<IClientMessageInspector>().Object;
    var behavior = new CeidgEndpointBehavior(inspector);

    var contract = ContractDescription.GetContract(typeof(IDisposable));
    var endpoint = new ServiceEndpoint(contract);

    var ctor = typeof(ClientRuntime)
        .GetConstructors(BindingFlags.Instance | BindingFlags.NonPublic)
        .First();

    var clientRuntime = (ClientRuntime)ctor.Invoke(new object[] { "test", "test" });

    var act = () => behavior.ApplyClientBehavior(endpoint, clientRuntime);

    act.Should().NotThrow();
}
}
