public interface IMapper
{
    TTarget Map<TTarget>(object source);

    List<TTarget> MapList<TTarget>(IEnumerable<object> source);
}


public class SimpleMapper : IMapper
{
    public TTarget Map<TTarget>(object source)
    {
        if (source == null) return default;

        return source switch
        {
            // Error
            Microservice.Common.Validation.Error e 
                when typeof(TTarget) == typeof(TransferError)
                => (TTarget)(object)e.ToTransferError(),

            Common.Rest.BMDomainMicroAccountingApi.TransferError e 
                when typeof(TTarget) == typeof(Microservice.Common.Validation.Error)
                => (TTarget)(object)e.ToValidationError(),

            // Account
            Common.Rest.BMDomainAccountsResourceProxyApi.AccountItem a
                when typeof(TTarget) == typeof(TransferAccount)
                => (TTarget)(object)a.ToDomain(),

            // Transfer (jeśli masz)
            Transfer t when typeof(TTarget) == typeof(TransferDto)
                => (TTarget)(object)t.ToDto(this),

            _ => throw new InvalidOperationException(
                $"No mapping defined from {source.GetType().Name} to {typeof(TTarget).Name}")
        };
    }

    public List<TTarget> MapList<TTarget>(IEnumerable<object> source)
    {
        if (source == null) return new List<TTarget>();

        return source.Select(x => Map<TTarget>(x)).ToList();
    }
}





